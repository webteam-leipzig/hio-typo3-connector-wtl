mod.wizards.newContentElement.wizardItems {
    hio-publisher {
        elements {
            FeaturedProjects {
                iconIdentifier = tx-hio_typo3_connector_wtl-featured-projects
                title = LLL:EXT:hio_typo3_connector_wtl/Resources/Private/Language/locallang_be.xlf:hio.featuredProjects.title
                description = LLL:EXT:hio_typo3_connector_wtl/Resources/Private/Language/locallang_be.xlf:hio.featuredProjects.description
                tt_content_defValues {
                    CType = tx_hiotypo3connectorwtl_featured_projects
                }
            }
        }
        show := addToList(FeaturedProjects)
    }
}