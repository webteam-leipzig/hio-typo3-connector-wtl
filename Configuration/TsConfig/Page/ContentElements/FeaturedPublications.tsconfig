mod.wizards.newContentElement.wizardItems {
    hio-publisher {
        elements {
            FeaturedPublications {
                iconIdentifier = tx-hio_typo3_connector_wtl-featured-publications
                title = LLL:EXT:hio_typo3_connector_wtl/Resources/Private/Language/locallang_be.xlf:hio.featuredPublications.title
                description = LLL:EXT:hio_typo3_connector_wtl/Resources/Private/Language/locallang_be.xlf:hio.featuredPublications.description
                tt_content_defValues {
                    CType = tx_hiotypo3connectorwtl_featured_publications
                }
            }
        }
        show := addToList(FeaturedPublications)
    }
}
